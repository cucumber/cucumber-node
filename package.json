{
  "name": "@cucumber/node",
  "version": "0.7.1",
  "author": "David Goss (https://github.com/davidjgoss)",
  "license": "MIT",
  "type": "module",
  "repository": "github:cucumber/cucumber-node",
  "exports": {
    ".": "./lib/index.js",
    "./bootstrap": "./lib/bootstrap/index.js",
    "./reporters/*": "./lib/reporters/builtin/*.js",
    "./runner": "./lib/runner/index.js"
  },
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "coverage:check": "c8 --100 npm test",
    "coverage:report": "c8 --reporter html npm test",
    "docs": "typedoc",
    "exports:check": "api-extractor run --verbose",
    "exports:update": "api-extractor run --verbose --local",
    "fix": "biome check --write --error-on-warnings",
    "lint": "biome check --error-on-warnings",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit && npm run test:acceptance && npm run test:cck",
    "test:acceptance": "npm run build && mocha \"test/acceptance/*.spec.ts\"",
    "test:cck": "npm run build && mocha \"test/cck/*.spec.ts\"",
    "test:unit": "mocha \"src/**/*.spec.ts\""
  },
  "dependencies": {
    "@babel/code-frame": "^8.0.0",
    "@babel/generator": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@cucumber/ci-environment": "14.0.0",
    "@cucumber/core": "0.9.0",
    "@cucumber/cucumber-expressions": "20.0.0",
    "@cucumber/gherkin": "41.0.0",
    "@cucumber/html-formatter": "24.0.0",
    "@cucumber/junit-xml-formatter": "0.14.0",
    "@cucumber/messages": "34.0.1",
    "@cucumber/pretty-formatter": "4.0.0",
    "@cucumber/query": "16.0.1",
    "@cucumber/tag-expressions": "10.0.0",
    "@teppeis/multimaps": "3.0.0",
    "stack-utils": "2.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@cucumber/biome-config": "cucumber/biome-config#v0.6.0",
    "@cucumber/compatibility-kit": "^29.0.0",
    "@microsoft/api-extractor": "7.58.9",
    "@tsconfig/recommended": "^1.0.13",
    "@types/babel__code-frame": "^7.27.0",
    "@types/babel__generator": "^7.27.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/stack-utils": "^2.0.3",
    "c8": "^12.0.0",
    "chai": "^6.2.2",
    "chai-exclude": "^3.0.1",
    "mocha": "^11.4.0",
    "tsx": "^4.22.3",
    "type-fest": "^5.3.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.0"
  }
}
